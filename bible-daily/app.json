{
  "expo": {
    "name": "Bible Daily",
    "slug": "bible-daily",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "bible-daily",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bibledaily.app"
    },
    "android": {
      "package": "com.bibledaily.app",
      "adaptiveIcon": {
        "backgroundColor": "#7c3aed",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
